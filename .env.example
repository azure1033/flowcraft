# FlowCraft Environment Configuration
# Copy this file to .env and fill in your values
# WARNING: Never commit .env to version control!

# LLM Provider Configuration
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Alternative providers (future)
# ANTHROPIC_API_KEY=
# LLM_PROVIDER=anthropic

# Database (for future persistence, MVP uses in-memory)
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/flowcraft
# REDIS_URL=redis://localhost:6379

# API Authentication
API_KEY=flowcraft-dev-key-change-in-production

# Simulated Review Mode (auto-generates decisions, no human interaction needed)
ENABLE_SIMULATED_REVIEW=true
