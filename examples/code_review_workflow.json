{
  "nodes": [
    {"id": "plan", "type": "planner"},
    {"id": "exec", "type": "executor", "tools": ["code_exec"]},
    {"id": "review", "type": "reviewer", "human_confirm": true}
  ],
  "edges": [
    {"source": "plan", "target": "exec"},
    {"source": "exec", "target": "review"},
    {"source": "review", "target": "exec", "condition": {"field": "review_decision", "op": "==", "value": "rejected"}, "loop": {"type": "retry", "max_retries": 2}},
    {"source": "review", "target": "__end__", "condition": {"field": "review_decision", "op": "==", "value": "approved"}}
  ]
}
